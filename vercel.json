{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "create-react-app"
        },
        "backend": {
            "root": "backend",
            "config": {
                "maxLambdaSize": "15mb"
            }
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "service": "backend/app.py"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "src/App.js"
            }
        }
    ]
}
