{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "create-react-app"
        },
        "backend": {
            "root": "backend",
            "config": {
                "maxLambdaSize": "15mb"
            }
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "src"
            }
        }
    ]
}
