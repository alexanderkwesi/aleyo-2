{
    "experimentalServices": {
        "frontend": {
            "path": "."
        },
        "backend": {
            "path": "backend",
            "functions": {
                "app.py": {
                    "maxDuration": 30
                }
            }
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
