{
  "name": "aleyo-web-builder",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "@formkit/auto-animate": "^0.9.0",
    "@mui/icons-material": "^5.14.19",
    "@mui/material": "5.14.20",
    "@openvizai/react": "^0.1.2",
    "apexcharts": "^5.10.4",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-apexcharts": "^2.1.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^6.20.0",
    "react-scripts": "^5.0.1",
    "web-vitals": "^5.2.0",
    "axios": "^1.7.9",
    "@google-cloud/storage": "^7.7.0"
  },
  "devDependencies": {
    "@babel/core": "7.23.5",
    "@babel/plugin-transform-runtime": "7.23.4",
    "@babel/preset-env": "7.23.5",
    "@babel/preset-react": "7.23.3",
    "@babel/runtime": "7.23.5",
    "ajv": "^6.12.6",
    "ajv-keywords": "^3.5.2",
    "babel-loader": "9.1.3",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "6.8.1",
    "html-webpack-plugin": "5.5.4",
    "style-loader": "3.3.3",
    "webpack": "5.89.0",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "4.15.1"
  },
  "scripts": {
    "start": "set PORT=4000 && react-scripts start",
    "install-script": "powershell -ExecutionPolicy Bypass -File .\\install.ps1",
    "dev": "concurrently \"npm run start\" \"python ./backend/app.py\"",
    "startall": "webpack serve --mode development",
    "build": "webpack --mode production",
    "prestart": "npm run install-script",
    "install-script-all": "powershell -ExecutionPolicy Bypass -File .\\install.ps1",
    "start:https": "webpack serve --mode development --open --https",
    "start:network": "webpack serve --mode development --open --host 0.0.0.0",
    "build:analyze": "webpack --mode production --profile --json > stats.json && webpack-bundle-analyzer stats.json",
    "dev-all": "concurrently \"npm run startall\" \"python ./backend/app.py\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
