{
    "builds": [
        {
            "src": "backend/app.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb" }
        }
    ],
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
