{
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": "https://aleyo-2-1.onrender.com"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
},
{
  "routes": [
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
