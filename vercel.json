{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "create-react-app"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "app.py"
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
